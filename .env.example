# Restora environment variables.
# Copy this file to .env.local (NEVER commit .env.local) and fill in values.
# Vite dev server (via vite.config.js middleware) and Vercel production both
# read these at runtime.

# Anthropic API key — required for:
#   • X-ray Analysis        (api/analyze-radiograph.js)
#   • Smile Creator AI auto-place (api/detect-smile-landmarks.js)
# Generate a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Resend API key — required for Export Hub "Send to Lab" SMTP
# (api/send-to-lab.js). Optional if you don't use the lab-send flow.
RESEND_API_KEY=
